{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and coin balance",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username" },
        "coins": { "type": "number", "description": "Current coin balance" },
        "joinedAt": { "type": "string", "format": "date-time", "description": "When the user joined" }
      },
      "required": ["username", "coins", "joinedAt"]
    },
    "Match": {
      "title": "Match",
      "description": "IPL match data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homeTeam": { "type": "object" },
        "awayTeam": { "type": "object" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Upcoming", "Live", "Completed"] },
        "venue": { "type": "string" },
        "score": { "type": "object" },
        "result": { "type": "object" }
      },
      "required": ["id", "homeTeam", "awayTeam", "startTime", "status", "venue"]
    },
    "Pick": {
      "title": "Pick",
      "description": "A user's bet on a match",
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "username": { "type": "string" },
        "teamId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Won", "Lost", "Refunded"] }
      },
      "required": ["matchId", "username", "teamId", "timestamp", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "matchId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["Bet", "Win", "Refund", "Initial"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["id", "username", "amount", "type", "timestamp", "description"]
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "IPL matches"
    },
    "/picks/{pickId}": {
      "schema": "Pick",
      "description": "User bets"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Wallet history"
    }
  }
}
